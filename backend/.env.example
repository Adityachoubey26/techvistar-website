# TechVistar Backend — production environment template
# Copy values into your hosting provider (Railway, Render, etc.). Do not commit real secrets.

NODE_ENV=production
PORT=5000

# Frontend URL (must match deployed Vercel/custom domain exactly)
CLIENT_URL=https://techvistar-website.vercel.app

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/techvistar?retryWrites=true&w=majority

# JWT — use long random strings in production
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Cloudinary (same account as local dev)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional — contact / newsletter email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=TechVistar <no-reply@techvistar.in>

# Optional — admin seed (run seed script once only, not on every deploy)
DEFAULT_ADMIN_EMAIL=admin@techvistar.com
DEFAULT_ADMIN_PASSWORD=
