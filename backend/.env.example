# ════════════════════════════════════════════════════════════════════
#  TechVistar API — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development           # development | production | test
PORT=5000
CLIENT_URL=http://localhost:8080
API_PREFIX=/api

# ── MongoDB ─────────────────────────────────────────────────────────
# Local (Phase 1 dev):
MONGODB_URI=mongodb://localhost:27017/techvistar
# Atlas (production — replace with your cluster URI):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/techvistar?retryWrites=true&w=majority

# ── JWT Authentication (Phase 2) ────────────────────────────────────
JWT_SECRET=replace_with_strong_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_strong_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Cloudinary — Media Uploads (Phase 3) ────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email — Nodemailer (Phase 3) ────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM=TechVistar <no-reply@techvistar.in>

# ── AI Services (Phase 4) ───────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# ── Logging ─────────────────────────────────────────────────────────
# Levels: error | warn | info | http | debug
# Development default: http (shows HTTP requests + warnings + errors)
# Production default:  warn  (only warnings and errors)
LOG_LEVEL=http

# ── File Uploads ────────────────────────────────────────────────────
UPLOAD_DIR=uploads
